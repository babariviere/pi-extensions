  "dependencies": {
    "defuddle": "^0.19.1",
    "linkedom": "^0.18.13",
    "parse5": "^8.0.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.2"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "scripts": {
    "test": "node --import tsx --test 'extensions/**/*.test.ts'",
    "typecheck": "tsc -p tsconfig.json"
  }
}
